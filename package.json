{
  "name": "open-vscode",
  "version": "1.5.0",
  "description": "Open vault in Visual Studio Code ribbon button and command for Obsidian (https://obsidian.md)",
  "main": "main.js",
  "author": "NomarCub",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22.18"
  },
  "scripts": {
    "dev": "node esbuild.config.mts",
    "build": "node esbuild.config.mts production",
    "check": "npm run type-check && npm run lint && npm run format",
    "type-check": "tsc",
    "lint": "biome lint && eslint",
    "lint:fix": "biome lint --fix && eslint --fix",
    "format": "biome format",
    "format:fix": "biome format --write",
    "version": "node version-bump.mts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@eslint/js": "^9.39.4",
    "@types/node": "~22.18.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.1.9",
    "obsidian": "1.12.3",
    "obsidian-typings": "6.13.0",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  }
}
